#!/usr/bin/env node
import { readdirSync } from "node:fs";
import path from "node:path";

const cwd = process.cwd();
const bugDir = path.join(cwd, "AGENTS", "bug_report");

try {
  const reports = readdirSync(bugDir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.endsWith(".md") && entry.name !== "CONTRACT.md")
    .map((entry) => ({
      name: entry.name,
      path: `AGENTS/bug_report/${entry.name}`,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

  process.stdout.write(JSON.stringify({
    ok: true,
    result: {
      count: reports.length,
      reports,
    },
  }) + "\n");
} catch (error) {
  process.stdout.write(JSON.stringify({
    ok: false,
    error: {
      type: "not_found",
      message: error instanceof Error ? error.message : "Bug report directory not found.",
    },
  }) + "\n");
}
