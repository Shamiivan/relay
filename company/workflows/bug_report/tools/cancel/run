#!/usr/bin/env node
import { readFileSync } from "node:fs";

const raw = readFileSync(0, "utf8").trim();

if (!raw) {
  process.stdout.write(JSON.stringify({
    ok: false,
    error: {
      type: "invalid_input",
      message: "Expected JSON on stdin. Provide a cancellation reason.",
    },
  }) + "\n");
  process.exit(0);
}

try {
  const input = JSON.parse(raw);
  if (typeof input.reason !== "string" || input.reason.trim().length === 0) {
    process.stdout.write(JSON.stringify({
      ok: false,
      error: {
        type: "validation",
        message: "reason must be a non-empty string",
      },
    }) + "\n");
    process.exit(0);
  }

  process.stdout.write(JSON.stringify({
    ok: true,
    result: {
      reason: input.reason.trim(),
      terminal: {
        status: "complete",
        instruction: "Call done_for_now next.",
      },
    },
  }) + "\n");
} catch (error) {
  process.stdout.write(JSON.stringify({
    ok: false,
    error: {
      type: "invalid_input",
      message: error instanceof Error ? error.message : "Expected valid JSON on stdin.",
    },
  }) + "\n");
}
