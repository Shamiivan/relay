{
  "name": "relay",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "bot": "tsx apps/bot/src/index.ts",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen",
    "worker": "tsx runtime/src/worker.ts",
    "dev": "concurrently -k -n convex,worker,bot -c blue,yellow,green \"pnpm convex:dev\" \"pnpm worker\" \"pnpm bot\"",
    "check": "tsc -p tsconfig.base.json --noEmit"
  },
  "dependencies": {
    "convex": "^1.32.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^148.0.0",
    "tsx": "^4.21.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
