# Convex (backend)
CONVEX_URL=
CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Discord bot (primary transport)
DISCORD_TOKEN=
DISCORD_PERMISSION_INTEGER=

# Google OAuth2 for Gmail / Drive / Docs / Sheets / Calendar
# Run `pnpm gmail:connect` to obtain the refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Model runtime
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Observability (Pino + Axiom). Optional.
AXIOM_TOKEN=
AXIOM_DATASET=
LOG_LEVEL=info
TRACE_DIR=.relay/logs/traces/

# Optional integrations (only needed for the corresponding workflows)
APOLLO_API_KEY=
BRAVE_API_KEY=
INSTANTLY_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=
