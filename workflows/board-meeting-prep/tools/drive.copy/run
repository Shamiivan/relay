#!/usr/bin/env node
// Self-contained Google Drive copy tool
// Requires: GOOGLE_TOKEN_PATH env var pointing to a valid OAuth token JSON file

import { createInterface } from "node:readline";
import { request as httpsRequest } from "node:https";
import { existsSync, readFileSync } from "node:fs";

function googlePost(url, body, accessToken) {
  return new Promise((resolve, reject) => {
    const payload = JSON.stringify(body);
    const urlObj = new URL(url);
    const options = {
      hostname: urlObj.hostname,
      path: urlObj.pathname + urlObj.search,
      method: "POST",
      headers: {
        Authorization: `Bearer ${accessToken}`,
        "Content-Type": "application/json",
        "Content-Length": Buffer.byteLength(payload),
      },
    };
    const req = httpsRequest(options, (res) => {
      let data = "";
      res.on("data", (chunk) => (data += chunk));
      res.on("end", () => {
        try {
          resolve(JSON.parse(data));
        } catch {
          reject(new Error(`Invalid JSON: ${data.slice(0, 200)}`));
        }
      });
    });
    req.on("error", reject);
    req.write(payload);
    req.end();
  });
}

const rl = createInterface({ input: process.stdin });
const lines = [];
rl.on("line", (l) => lines.push(l));
rl.on("close", async () => {
  try {
    const input = JSON.parse(lines.join(""));
    const { fileId, name, parentId } = input;

    const tokenPath = process.env.GOOGLE_TOKEN_PATH;
    if (!tokenPath || !existsSync(tokenPath)) {
      process.stderr.write("[drive.copy] GOOGLE_TOKEN_PATH not set or file not found\n");
      process.stdout.write(JSON.stringify({ error: { message: "OAuth not configured" } }) + "\n");
      return;
    }

    const token = JSON.parse(readFileSync(tokenPath, "utf8"));
    const accessToken = token.access_token;

    const body = { name };
    if (parentId) body.parents = [parentId];

    const fields = encodeURIComponent("id,name,mimeType,webViewLink");
    const url = `https://www.googleapis.com/drive/v3/files/${fileId}/copy?fields=${fields}&supportsAllDrives=true`;
    const result = await googlePost(url, body, accessToken);
    process.stdout.write(JSON.stringify(result) + "\n");
  } catch (err) {
    process.stderr.write(String(err) + "\n");
    process.exit(1);
  }
});
