#!/usr/bin/env node
// Self-contained Google Drive search tool
// Requires: GOOGLE_TOKEN_PATH env var pointing to a valid OAuth token JSON file

import { createInterface } from "node:readline";
import { createServer } from "node:https";
import { get as httpsGet } from "node:https";
import { existsSync, readFileSync } from "node:fs";

function googleGet(url, accessToken) {
  return new Promise((resolve, reject) => {
    const req = httpsGet(url, { headers: { Authorization: `Bearer ${accessToken}` } }, (res) => {
      let data = "";
      res.on("data", (chunk) => (data += chunk));
      res.on("end", () => {
        try {
          resolve(JSON.parse(data));
        } catch {
          reject(new Error(`Invalid JSON response: ${data.slice(0, 200)}`));
        }
      });
    });
    req.on("error", reject);
  });
}

const rl = createInterface({ input: process.stdin });
const lines = [];
rl.on("line", (l) => lines.push(l));
rl.on("close", async () => {
  try {
    const input = JSON.parse(lines.join(""));
    const { query, maxResults = 10 } = input;

    const tokenPath = process.env.GOOGLE_TOKEN_PATH;
    if (!tokenPath || !existsSync(tokenPath)) {
      process.stderr.write("[drive.search] GOOGLE_TOKEN_PATH not set or file not found\n");
      process.stdout.write(JSON.stringify({ files: [] }) + "\n");
      return;
    }

    const token = JSON.parse(readFileSync(tokenPath, "utf8"));
    const accessToken = token.access_token;

    const encodedQuery = encodeURIComponent(query);
    const fields = encodeURIComponent(
      "files(id,name,mimeType,webViewLink,parents,modifiedTime,driveId,owners)",
    );
    const url = `https://www.googleapis.com/drive/v3/files?q=${encodedQuery}&pageSize=${maxResults}&fields=${fields}&includeItemsFromAllDrives=true&supportsAllDrives=true&corpora=allDrives`;

    const result = await googleGet(url, accessToken);
    process.stdout.write(JSON.stringify(result) + "\n");
  } catch (err) {
    process.stderr.write(String(err) + "\n");
    process.exit(1);
  }
});
