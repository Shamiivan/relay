#!/usr/bin/env node
// Self-contained Google Docs write tool
// Requires: GOOGLE_TOKEN_PATH env var pointing to a valid OAuth token JSON file

import { createInterface } from "node:readline";
import { request as httpsRequest, get as httpsGet } from "node:https";
import { existsSync, readFileSync } from "node:fs";

function googleRequest(method, url, body, accessToken) {
  return new Promise((resolve, reject) => {
    const payload = JSON.stringify(body);
    const urlObj = new URL(url);
    const options = {
      hostname: urlObj.hostname,
      path: urlObj.pathname + urlObj.search,
      method,
      headers: {
        Authorization: `Bearer ${accessToken}`,
        "Content-Type": "application/json",
        "Content-Length": Buffer.byteLength(payload),
      },
    };
    const req = httpsRequest(options, (res) => {
      let data = "";
      res.on("data", (chunk) => (data += chunk));
      res.on("end", () => {
        try {
          resolve(JSON.parse(data));
        } catch {
          reject(new Error(`Invalid JSON: ${data.slice(0, 200)}`));
        }
      });
    });
    req.on("error", reject);
    req.write(payload);
    req.end();
  });
}

const rl = createInterface({ input: process.stdin });
const lines = [];
rl.on("line", (l) => lines.push(l));
rl.on("close", async () => {
  try {
    const input = JSON.parse(lines.join(""));
    const { documentId, text } = input;

    const tokenPath = process.env.GOOGLE_TOKEN_PATH;
    if (!tokenPath || !existsSync(tokenPath)) {
      process.stderr.write("[docs.write] GOOGLE_TOKEN_PATH not set or file not found\n");
      process.stdout.write(
        JSON.stringify({ documentId, error: { message: "OAuth not configured" } }) + "\n",
      );
      return;
    }

    const token = JSON.parse(readFileSync(tokenPath, "utf8"));
    const accessToken = token.access_token;

    const docRes = await googleRequest(
      "GET",
      `https://docs.googleapis.com/v1/documents/${documentId}`,
      {},
      accessToken,
    );
    if (docRes.error) {
      process.stdout.write(JSON.stringify({ documentId, error: docRes.error }) + "\n");
      return;
    }

    const endIndex = docRes.body?.content?.at(-1)?.endIndex ?? 1;
    const requests = [];
    if (endIndex > 1) {
      requests.push({ deleteContentRange: { range: { startIndex: 1, endIndex: endIndex - 1 } } });
    }
    requests.push({ insertText: { location: { index: 1 }, text } });

    const result = await googleRequest(
      "POST",
      `https://docs.googleapis.com/v1/documents/${documentId}:batchUpdate`,
      { requests },
      accessToken,
    );

    if (result.error) {
      process.stdout.write(JSON.stringify({ documentId, error: result.error }) + "\n");
    } else {
      process.stdout.write(JSON.stringify({ documentId, success: true }) + "\n");
    }
  } catch (err) {
    process.stderr.write(String(err) + "\n");
    process.exit(1);
  }
});
